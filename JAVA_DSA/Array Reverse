https://www.geeksforgeeks.org/problems/reverse-an-array/1

class Solution{
    public static void reverseArray(int arr[]){
        int first = 0;
        int last = arr.length-1;
        while(first < last){
            int temp = arr[first];
            arr[first] = arr[last];
            arr[last] = temp;
            first++;
            last--;
        }
    }
}
