class Solution {
    public ArrayList<Integer> getMinMax(int[] arr) {
        // code Here
         int min = arr[0];
        int max = arr[0];
        
        // Traverse the array
        for (int i = 1; i < arr.length; i++) {
            
            // Update minimum
            if (arr[i] < min) {
                min = arr[i];
            }
            
            // Update maximum
            if (arr[i] > max) {
                max = arr[i];
            }
        }
        
        ArrayList<Integer> result = new ArrayList<>();
        result.add(min);
        result.add(max);
        
        return result;
        
    }
}
